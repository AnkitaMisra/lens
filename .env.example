# Lens configuration
# Copy this file to .env and fill in your values

# Required — get from console.anthropic.com
ANTHROPIC_API_KEY=your_key_here

# Optional — database location (default: ./data/lens.db)
LENS_DB_PATH=./data/lens.db

# Optional — web UI port (default: 8000)
LENS_PORT=8000

# Optional — log level (default: INFO)
LENS_LOG_LEVEL=INFO
